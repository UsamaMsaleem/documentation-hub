<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Email Verification</title>
    </head>
    <body
        style="margin: 0; padding: 0; background-color: #f4f4f4; font-family: Arial, sans-serif;">

        <table width="100%" border="0" cellspacing="0" cellpadding="0"
            style="background-color: #f4f4f4; padding: 20px 0;">
            <tr>
                <td align="center">
                    <table width="600" border="0" cellspacing="0"
                        cellpadding="0"
                        style="background-color: #ffffff; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 10px rgba(0,0,0,0.05);">

                        <tr>
                            <td align="center"
                                style="padding: 40px 20px 20px 20px;">
                                <h2
                                    style="margin: 0; color: #333333; font-size: 24px; font-weight: bold;">
                                    Verify Your Email Address
                                </h2>
                            </td>
                        </tr>

                        <tr>
                            <td
                                style="padding: 20px 40px; color: #555555; font-size: 16px; line-height: 1.6; text-align: left;">
                                <p style="margin: 0 0 15px 0;">Hello,</p>
                                <p style="margin: 0 0 20px 0;">
                                    Thank you for registering on our website. To
                                    complete your signup process and activate
                                    your account, please verify your email
                                    address by clicking the button below.
                                </p>
                            </td>
                        </tr>

                        <tr>
                            <td align="center"
                                style="padding: 10px 40px 30px 40px;">
                                <a href="http://localhost:5173/verify/{{token}}"
                                    target="_blank"
                                    style="background-color: #00a63d; color: #ffffff; display: inline-block; padding: 12px 30px; border-radius: 5px; text-decoration: none; font-weight: bold; font-size: 16px;">
                                    Verify Your Email
                                </a>
                            </td>
                        </tr>

                        <tr>
                            <td
                                style="padding: 0 40px 40px 40px; color: #888888; font-size: 14px; text-align: left;">
                                <p style="margin: 0;">If you did not initiate
                                    this request, you can safely ignore this
                                    email.</p>
                            </td>
                        </tr>

                        <tr>
                            <td align="center"
                                style="padding: 20px; background-color: #fafafa; color: #aaaaaa; font-size: 12px;">
                                <p style="margin: 0;">&copy; 2025 Website
                                    Builder. All rights reserved.</p>
                            </td>
                        </tr>

                    </table>
                </td>
            </tr>
        </table>

    </body>
</html>